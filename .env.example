# Public application URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=Highground

# Supabase — browser-safe values
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Supabase — server only; never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=

# Stripe — server only except the publishable key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Transactional email
RESEND_API_KEY=
EMAIL_FROM=Highground <notifications@example.com>
SUPPORT_EMAIL=support@example.com

# Bot protection
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Optional integrations
SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Development only. Never enable on a public production deployment.
ENABLE_DEMO_PORTALS=false
